# 设置固件大小:
CONFIG_TARGET_ROOTFS_PARTSIZE=120

CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y

# EFI支持:
CONFIG_GRUB_IMAGES=n
CONFIG_EFI_IMAGES=n
CONFIG_VMDK_IMAGES=n
CONFIG_TARGET_ROOTFS_TARGZ=y

CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_flow-offload=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_shortcut-fe=n

# 其他需要安装的软件包:
CONFIG_PACKAGE_luci-proto-bonding=y
CONFIG_PACKAGE_autocore-x86=y

# Wireless
CONFIG_PACKAGE_wpad-basic-wolfssl=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_iwinfo=n

# x86
CONFIG_PACKAGE_kmod-usb-hid=y
CONFIG_PACKAGE_qemu-ga=y
CONFIG_PACKAGE_lm-sensors-detect=y
CONFIG_PACKAGE_kmod-bonding=y
CONFIG_PACKAGE_kmod-mmc-spi=y
CONFIG_PACKAGE_kmod-sdhci=y
CONFIG_PACKAGE_kmod-vmxnet3=y
CONFIG_PACKAGE_kmod-igbvf=y
CONFIG_PACKAGE_kmod-ixgbe=y
CONFIG_PACKAGE_kmod-pcnet32=y
CONFIG_PACKAGE_kmod-r8125=y
CONFIG_PACKAGE_kmod-r8168=y
CONFIG_PACKAGE_kmod-8139cp=y
CONFIG_PACKAGE_kmod-8139too=y
CONFIG_PACKAGE_kmod-i40e=y
CONFIG_PACKAGE_kmod-i40evf=y
CONFIG_PACKAGE_kmod-ath5k=y
CONFIG_PACKAGE_kmod-ath9k=y
CONFIG_PACKAGE_kmod-ath9k-htc=y
CONFIG_PACKAGE_kmod-ath10k=y
CONFIG_PACKAGE_kmod-rt2800-usb=y
CONFIG_PACKAGE_kmod-mlx4-core=y
CONFIG_PACKAGE_kmod-mlx5-core=y
CONFIG_PACKAGE_kmod-tulip=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_ath10k-firmware-qca9888=y
CONFIG_PACKAGE_ath10k-firmware-qca988x=y
CONFIG_PACKAGE_ath10k-firmware-qca9984=y
CONFIG_PACKAGE_brcmfmac-firmware-43602a1-pcie=y
CONFIG_PACKAGE_kmod-ac97=y
CONFIG_PACKAGE_kmod-sound-via82xx=y
CONFIG_PACKAGE_alsa-utils=y

# USB3.0支持:
CONFIG_PACKAGE_kmod-usb2=n
CONFIG_PACKAGE_kmod-usb2-pci=n
CONFIG_PACKAGE_kmod-usb3=n
CONFIG_PACKAGE_kmod-usb-audio=n
CONFIG_PACKAGE_kmod-usb-printer=n
CONFIG_PACKAGE_automount=n
CONFIG_PACKAGE_autosamba=n
CONFIG_PACKAGE_autosamba-ksmbd=n
#ksmbd
CONFIG_PACKAGE_kmod-fs-ksmbd=y
#nfs
CONFIG_PACKAGE_kmod-fs-nfsd=n
CONFIG_PACKAGE_kmod-fs-nfs=n
CONFIG_PACKAGE_kmod-fs-nfs-v4=n
#3G/4G Support
CONFIG_PACKAGE_kmod-usb-serial=n
CONFIG_PACKAGE_kmod-usb-serial-option=n
CONFIG_PACKAGE_kmod-usb-serial-wwan=n
CONFIG_PACKAGE_kmod-mii=n
CONFIG_PACKAGE_kmod-usb-acm=n
#Sound Support
CONFIG_PACKAGE_kmod-sound-core=n
CONFIG_PACKAGE_kmod-sound-hda-core=n
CONFIG_PACKAGE_kmod-sound-hda-codec-realtek=n
CONFIG_PACKAGE_kmod-sound-hda-codec-via=n
CONFIG_PACKAGE_kmod-sound-hda-intel=n
CONFIG_PACKAGE_kmod-sound-hda-codec-hdmi=n
#USB net driver
CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_PACKAGE_kmod-rtlwifi=n
CONFIG_PACKAGE_kmod-rtlwifi-btcoexist=n
CONFIG_PACKAGE_kmod-rtlwifi-usb=n
CONFIG_PACKAGE_usb-modeswitch=n
CONFIG_PACKAGE_kmod-rtl8192cu=n
CONFIG_PACKAGE_kmod-mt76x2u=n
CONFIG_PACKAGE_kmod-usb-net-asix=n
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=n
CONFIG_PACKAGE_kmod-usb-net-rtl8152-vendor=n

# docker
CONFIG_PACKAGE_docker-ce=n
CONFIG_PACKAGE_kmod-fs-btrfs=n
CONFIG_PACKAGE_kmod-dm=n
CONFIG_PACKAGE_kmod-br-netfilter=n
CONFIG_PACKAGE_kmod-ikconfig=n
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=n
CONFIG_PACKAGE_kmod-nf-ipvs=n
CONFIG_PACKAGE_kmod-veth=n
CONFIG_PACKAGE_kmod-dummy=n
